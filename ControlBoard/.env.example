# AWS IoT
AWS_IOT_ENDPOINT=your-aws-iot-endpoint-ats.iot.your-region.amazonaws.com
CLIENT_ID=controlBoardClient
AWS_IOT_CERT_PATH=Backend/Utils/Certificates/controlboardbackend-certificate.pem.crt
AWS_IOT_KEY_PATH=Backend/Utils/Keys/controlboardbackend-private.pem.key
AWS_IOT_CA_PATH=Backend/Utils/CA/AmazonRootCA1.pem

# MQTT Topics
MACHINE_SIGNAL_TOPIC=machine/signal
CLOUD_VERDICT_TOPIC=cloud/verdict
SENSOR_DATA_TOPIC=sensor/data

# Flask
FLASK_SECRET=change-me-long-random-string
CONTROLBOARD_DB_PATH=/app/data/controlboard.db

# Local links shown by the dashboard
DIGITAL_TWIN_BASE_URL=http://localhost:8000/
DASHBOARD_BASE_URL=http://localhost:8086/
