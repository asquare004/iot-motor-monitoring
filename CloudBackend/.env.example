# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change-me
INFLUXDB_ORG=iotproject
INFLUXDB_BUCKET=sensordata
INFLUXDB_TOKEN=change-me-long-random-token
INFLUXDB_URL=http://influxdb:8086

# AWS IoT
AWS_IOT_ENDPOINT=your-aws-iot-endpoint-ats.iot.your-region.amazonaws.com
CLIENT_ID=cloudClient
AWS_IOT_CERT_PATH=Certificates/cloud-certificate.pem.crt
AWS_IOT_KEY_PATH=Keys/cloud-private.pem.key
AWS_IOT_CA_PATH=CA/AmazonRootCA1.pem

# MQTT Topics
SENSOR_DATA_TOPIC=sensor/data
AI_VERDICT_TOPIC=cloud/verdict
SIGNAL_TOPIC=machine/signal

# Email settings. Leave blank to disable email alerts.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_SENDER=
ALERT_RECIPIENT=

# AI
AI_TRAIN_RANGE=-1m
AI_INFER_RANGE=-3m
AI_MODEL_PATH=/app/AI/models/iforest.joblib
AI_META_PATH=/app/AI/models/iforest.meta.json
AI_WARN_ANOMALY=0.60
AI_STOP_ANOMALY=0.85
